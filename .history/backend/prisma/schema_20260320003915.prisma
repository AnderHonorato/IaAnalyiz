-- ============================================================
-- MIGRATION MULTI-TENANT SEGURA — Execute no Neon SQL Editor
-- console.neon.tech → seu projeto → SQL Editor → cole e execute
--
-- NUNCA rode npx prisma db push com dados existentes.
-- Após executar este SQL, rode APENAS: npx prisma generate
-- ============================================================

-- ── 1. Colunas novas em Usuario ──────────────────────────────
ALTER TABLE "Usuario"
  ADD COLUMN IF NOT EXISTS "tema"                 TEXT    NOT NULL DEFAULT 'dark',
  ADD COLUMN IF NOT EXISTS "exclusaoPendente"     BOOLEAN NOT NULL DEFAULT false,
  ADD COLUMN IF NOT EXISTS "exclusaoCodigoHash"   TEXT,
  ADD COLUMN IF NOT EXISTS "exclusaoSolicitadaEm" TIMESTAMP(3);

-- ── 2. Colunas novas em Produto ──────────────────────────────
ALTER TABLE "Produto"
  ADD COLUMN IF NOT EXISTS "usuarioId"      INTEGER,
  ADD COLUMN IF NOT EXISTS "categoria"      TEXT,
  ADD COLUMN IF NOT EXISTS "status"         TEXT    NOT NULL DEFAULT 'active',
  ADD COLUMN IF NOT EXISTS "thumbnail"      TEXT,
  ADD COLUMN IF NOT EXISTS "alturaCm"       DOUBLE PRECISION NOT NULL DEFAULT 0,
  ADD COLUMN IF NOT EXISTS "larguraCm"      DOUBLE PRECISION NOT NULL DEFAULT 0,
  ADD COLUMN IF NOT EXISTS "comprimentoCm"  DOUBLE PRECISION NOT NULL DEFAULT 0;

-- ── 3. Colunas novas em Divergencia ──────────────────────────
ALTER TABLE "Divergencia"
  ADD COLUMN IF NOT EXISTS "usuarioId"  INTEGER,
  ADD COLUMN IF NOT EXISTS "pesoMl"     INTEGER NOT NULL DEFAULT 0,
  ADD COLUMN IF NOT EXISTS "pesoLocal"  INTEGER NOT NULL DEFAULT 0,
  ADD COLUMN IF NOT EXISTS "status"     TEXT    NOT NULL DEFAULT 'PENDENTE',
  ADD COLUMN IF NOT EXISTS "titulo"     TEXT;

-- ── 4. Criar MlToken se não existir ──────────────────────────
CREATE TABLE IF NOT EXISTS "MlToken" (
  "id"           SERIAL PRIMARY KEY,
  "usuarioId"    INTEGER NOT NULL,
  "accessToken"  TEXT    NOT NULL DEFAULT '',
  "refreshToken" TEXT    NOT NULL DEFAULT '',
  "expiresAt"    TIMESTAMP(3) NOT NULL DEFAULT NOW(),
  "mlUserId"     TEXT    NOT NULL DEFAULT '',
  "nickname"     TEXT    NOT NULL DEFAULT '',
  "createdAt"    TIMESTAMP(3) NOT NULL DEFAULT NOW()
);

-- Adiciona colunas que podem estar faltando em MlToken existente
DO $$ BEGIN
  IF NOT EXISTS (SELECT 1 FROM information_schema.columns 
                 WHERE table_name='MlToken' AND column_name='usuarioId') THEN
    ALTER TABLE "MlToken" ADD COLUMN "usuarioId" INTEGER NOT NULL DEFAULT 0;
  END IF;

  IF NOT EXISTS (SELECT 1 FROM information_schema.columns 
                 WHERE table_name='MlToken' AND column_name='mlUserId') THEN
    IF EXISTS (SELECT 1 FROM information_schema.columns 
               WHERE table_name='MlToken' AND column_name='userId') THEN
      EXECUTE 'ALTER TABLE "MlToken" RENAME COLUMN "userId" TO "mlUserId"';
    ELSE
      ALTER TABLE "MlToken" ADD COLUMN "mlUserId" TEXT NOT NULL DEFAULT '';
    END IF;
  END IF;
END $$;

-- ── 5. Criar AgendadorConfig se não existir ──────────────────
CREATE TABLE IF NOT EXISTS "AgendadorConfig" (
  "id"              SERIAL PRIMARY KEY,
  "usuarioId"       INTEGER NOT NULL,
  "ativo"           BOOLEAN NOT NULL DEFAULT false,
  "intervalo"       INTEGER NOT NULL DEFAULT 360,
  "ultimaExecucao"  TIMESTAMP(3),
  "proximaExecucao" TIMESTAMP(3)
);

DO $$ BEGIN
  IF NOT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_name='AgendadorConfig' AND column_name='usuarioId') THEN
    ALTER TABLE "AgendadorConfig" ADD COLUMN "usuarioId" INTEGER NOT NULL DEFAULT 0;
  END IF;
END $$;

-- ── 6. Atribuir OWNER como dono dos dados existentes sem dono ─
DO $$
DECLARE owner_id INTEGER;
BEGIN
  SELECT id INTO owner_id FROM "Usuario" WHERE role = 'OWNER' ORDER BY id LIMIT 1;
  IF owner_id IS NULL THEN
    SELECT id INTO owner_id FROM "Usuario" ORDER BY id LIMIT 1;
  END IF;
  IF owner_id IS NOT NULL THEN
    UPDATE "Produto"         SET "usuarioId" = owner_id WHERE "usuarioId" IS NULL;
    UPDATE "Divergencia"     SET "usuarioId" = owner_id WHERE "usuarioId" IS NULL;
    UPDATE "MlToken"         SET "usuarioId" = owner_id WHERE "usuarioId" = 0 OR "usuarioId" IS NULL;
    UPDATE "AgendadorConfig" SET "usuarioId" = owner_id WHERE "usuarioId" = 0 OR "usuarioId" IS NULL;
  END IF;
END $$;

-- ── 7. Tornar NOT NULL após preencher ─────────────────────────
ALTER TABLE "Produto"     ALTER COLUMN "usuarioId" SET NOT NULL;
ALTER TABLE "Divergencia" ALTER COLUMN "usuarioId" SET NOT NULL;

-- ── 8. Migrar resolvido → status nas divergências existentes ──
UPDATE "Divergencia" SET "status" = 'CORRIGIDO' WHERE "resolvido" = true AND "status" = 'PENDENTE';

-- ── 9. Remover unique global de SKU e criar por usuário ───────
ALTER TABLE "Produto" DROP CONSTRAINT IF EXISTS "Produto_sku_key";
DO $$ BEGIN
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'Produto_usuarioId_sku_key') THEN
    ALTER TABLE "Produto" ADD CONSTRAINT "Produto_usuarioId_sku_key" UNIQUE ("usuarioId", "sku");
  END IF;
END $$;

-- ── 10. Unique por usuário em MlToken e AgendadorConfig ───────
DO $$ BEGIN
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'MlToken_usuarioId_key') THEN
    ALTER TABLE "MlToken" ADD CONSTRAINT "MlToken_usuarioId_key" UNIQUE ("usuarioId");
  END IF;
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'AgendadorConfig_usuarioId_key') THEN
    ALTER TABLE "AgendadorConfig" ADD CONSTRAINT "AgendadorConfig_usuarioId_key" UNIQUE ("usuarioId");
  END IF;
END $$;

-- ── 11. Índices de performance ────────────────────────────────
CREATE INDEX IF NOT EXISTS "Produto_usuarioId_idx"     ON "Produto"("usuarioId");
CREATE INDEX IF NOT EXISTS "Divergencia_usuarioId_idx" ON "Divergencia"("usuarioId");
CREATE INDEX IF NOT EXISTS "Produto_categoria_idx"     ON "Produto"("categoria");

-- ── 12. Foreign keys (opcional mas recomendado) ───────────────
DO $$ BEGIN
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'Produto_usuarioId_fkey') THEN
    ALTER TABLE "Produto" ADD CONSTRAINT "Produto_usuarioId_fkey"
      FOREIGN KEY ("usuarioId") REFERENCES "Usuario"("id") ON DELETE CASCADE;
  END IF;
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'Divergencia_usuarioId_fkey') THEN
    ALTER TABLE "Divergencia" ADD CONSTRAINT "Divergencia_usuarioId_fkey"
      FOREIGN KEY ("usuarioId") REFERENCES "Usuario"("id") ON DELETE CASCADE;
  END IF;
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'MlToken_usuarioId_fkey') THEN
    ALTER TABLE "MlToken" ADD CONSTRAINT "MlToken_usuarioId_fkey"
      FOREIGN KEY ("usuarioId") REFERENCES "Usuario"("id") ON DELETE CASCADE;
  END IF;
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'AgendadorConfig_usuarioId_fkey') THEN
    ALTER TABLE "AgendadorConfig" ADD CONSTRAINT "AgendadorConfig_usuarioId_fkey"
      FOREIGN KEY ("usuarioId") REFERENCES "Usuario"("id") ON DELETE CASCADE;
  END IF;
END $$;

