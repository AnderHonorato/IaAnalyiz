generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" 
  url      = env("DATABASE_URL")
}

model Usuario {
  id                Int      @id @default(autoincrement())
  email             String   @unique
  senha             String
  nome              String
  avatar            String?  // Novo campo para salvar a foto de perfil em Base64
  verificado        Boolean  @default(false)
  codigoVerificacao String?  
  codigoRecuperacao String?  
  createdAt         DateTime @default(now())
}

model Produto {
  id          Int       @id @default(autoincrement())
  sku         String    @unique
  nome        String
  preco       Float
  pesoGramas  Int
  eKit        Boolean   @default(false)
  mlItemId    String?   
  plataforma  String    @default("Mercado Livre") // Nova identificação
  itensDoKit  KitItem[] @relation("KitPai")
  parteDeKits KitItem[] @relation("ItemFilho")
}

model KitItem {
  id         Int     @id @default(autoincrement())
  kitId      Int
  produtoId  Int
  quantidade Int
  kit        Produto @relation("KitPai", fields: [kitId], references: [id])
  produto    Produto @relation("ItemFilho", fields: [produtoId], references: [id])
}

model Divergencia {
  id         Int      @id @default(autoincrement())
  mlItemId   String
  link       String
  motivo     String
  resolvido  Boolean  @default(false)
  plataforma String   @default("Mercado Livre") // Nova identificação
  createdAt  DateTime @default(now())
}