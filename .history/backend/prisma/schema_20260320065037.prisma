generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                   Int              @id @default(autoincrement())
  email                String           @unique
  senha                String
  nome                 String
  avatar               String?
  verificado           Boolean          @default(false)
  codigoVerificacao    String?
  codigoRecuperacao    String?
  role                 String           @default("BLOQUEADO")
  solicitouDesbloqueio Boolean          @default(false)
  tema                 String           @default("dark")

  exclusaoPendente     Boolean          @default(false)
  exclusaoCodigoHash   String?         
  exclusaoSolicitadaEm DateTime?       
  createdAt            DateTime         @default(now())
  chatSessions         ChatSession[]
  produtos             Produto[]
  divergencias         Divergencia[]
  mlToken              MlToken?
  agendador            AgendadorConfig?
  resumosIA            ResumoIA[]
}

model ChatSession {
  id        Int           @id @default(autoincrement())
  titulo    String        @default("Nova conversa")
  usuarioId Int
  usuario   Usuario       @relation(fields: [usuarioId], references: [id])
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ChatMessage {
  id          Int         @id @default(autoincrement())
  sessionId   Int
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role        String
  content     String      @db.Text
  imageBase64 String?     @db.Text
  imageDesc   String?     @db.Text
  createdAt   DateTime    @default(now())
}

model Produto {
  id            Int       @id @default(autoincrement())
  usuarioId     Int
  usuario       Usuario   @relation(fields: [usuarioId], references: [id])
  sku           String
  nome          String
  preco         Float     @default(0)
  pesoGramas    Int       @default(0)
  alturaCm      Float     @default(0)
  larguraCm     Float     @default(0)
  comprimentoCm Float     @default(0)
  eKit          Boolean   @default(false)
  mlItemId      String?
  categoria     String?
  plataforma    String    @default("Mercado Livre")
  status        String    @default("active")
  thumbnail     String?
  itensDoKit    KitItem[] @relation("KitPai")
  parteDeKits   KitItem[] @relation("ItemFilho")

  @@unique([usuarioId, sku])
}

model KitItem {
  id         Int     @id @default(autoincrement())
  kitId      Int
  produtoId  Int
  quantidade Int
  kit        Produto @relation("KitPai", fields: [kitId], references: [id])
  produto    Produto @relation("ItemFilho", fields: [produtoId], references: [id])
}

model Divergencia {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  mlItemId   String
  link       String
  motivo     String
  pesoMl     Int      @default(0)
  pesoLocal  Int      @default(0)
  status     String   @default("PENDENTE")
  resolvido  Boolean  @default(false)
  plataforma String   @default("Mercado Livre")
  titulo     String?
  createdAt  DateTime @default(now())
}

model MlToken {
  id           Int      @id @default(autoincrement())
  usuarioId    Int      @unique
  usuario      Usuario  @relation(fields: [usuarioId], references: [id])
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  mlUserId     String   @default("")
  nickname     String   @default("")
  createdAt    DateTime @default(now())
}

model AgendadorConfig {
  id              Int       @id @default(autoincrement())
  usuarioId       Int       @unique
  usuario         Usuario   @relation(fields: [usuarioId], references: [id])
  ativo           Boolean   @default(false)
  intervalo       Int       @default(360)
  ultimaExecucao  DateTime?
  proximaExecucao DateTime?
}

model ResumoIA {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  conteudo  String   @db.Text
  createdAt DateTime @default(now())
}
