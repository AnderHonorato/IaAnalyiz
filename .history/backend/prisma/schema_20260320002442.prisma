generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                   Int              @id @default(autoincrement())
  email                String           @unique
  senha                String
  nome                 String
  avatar               String?
  verificado           Boolean          @default(false)
  codigoVerificacao    String?
  codigoRecuperacao    String?
  role                 String           @default("BLOQUEADO")
  solicitouDesbloqueio Boolean          @default(false)
  tema                 String           @default("dark")   // tema de cores escolhido
  createdAt            DateTime         @default(now())
  chatSessions         ChatSession[]
  produtos             Produto[]        // produtos pertencem ao usuário
  divergencias         Divergencia[]    // divergências pertencem ao usuário
  mlToken              MlToken?         // token ML do usuário
  agendador            AgendadorConfig? // agendador do usuário
}

model ChatSession {
  id        Int           @id @default(autoincrement())
  titulo    String        @default("Nova conversa")
  usuarioId Int
  usuario   Usuario       @relation(fields: [usuarioId], references: [id])
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ChatMessage {
  id          Int         @id @default(autoincrement())
  sessionId   Int
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role        String
  content     String      @db.Text
  imageBase64 String?     @db.Text
  imageDesc   String?     @db.Text
  createdAt   DateTime    @default(now())
}

model Produto {
  id            Int       @id @default(autoincrement())
  usuarioId     Int                          // ← MULTI-TENANT
  usuario       Usuario   @relation(fields: [usuarioId], references: [id])
  sku           String
  nome          String
  preco         Float
  pesoGramas    Int
  alturaCm      Float     @default(0)
  larguraCm     Float     @default(0)
  comprimentoCm Float     @default(0)
  eKit          Boolean   @default(false)
  mlItemId      String?
  categoria     String?                      // categoria do produto/anúncio
  plataforma    String    @default("Mercado Livre")
  status        String    @default("active") // active | paused | closed
  thumbnail     String?                      // URL da imagem do anúncio
  itensDoKit    KitItem[] @relation("KitPai")
  parteDeKits   KitItem[] @relation("ItemFilho")

  @@unique([usuarioId, sku])               // SKU único POR usuário
}

model KitItem {
  id         Int     @id @default(autoincrement())
  kitId      Int
  produtoId  Int
  quantidade Int
  kit        Produto @relation("KitPai", fields: [kitId], references: [id])
  produto    Produto @relation("ItemFilho", fields: [produtoId], references: [id])
}

model Divergencia {
  id         Int      @id @default(autoincrement())
  usuarioId  Int                              // ← MULTI-TENANT
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  mlItemId   String
  link       String
  motivo     String
  pesoMl     Int      @default(0)
  pesoLocal  Int      @default(0)
  status     String   @default("PENDENTE")   // PENDENTE | CORRIGIDO | IGNORADO
  resolvido  Boolean  @default(false)
  plataforma String   @default("Mercado Livre")
  titulo     String?
  createdAt  DateTime @default(now())
}

// Token OAuth do ML — um por usuário
model MlToken {
  id           Int      @id @default(autoincrement())
  usuarioId    Int      @unique                // ← MULTI-TENANT (um token por user)
  usuario      Usuario  @relation(fields: [usuarioId], references: [id])
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  mlUserId     String   // user_id retornado pelo ML
  nickname     String   @default("")
  createdAt    DateTime @default(now())
}

// Agendador — um por usuário
model AgendadorConfig {
  id              Int       @id @default(autoincrement())
  usuarioId       Int       @unique             // ← MULTI-TENANT
  usuario         Usuario   @relation(fields: [usuarioId], references: [id])
  ativo           Boolean   @default(false)
  intervalo       Int       @default(360)
  ultimaExecucao  DateTime?
  proximaExecucao DateTime?
}
