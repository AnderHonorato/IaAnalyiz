// ═══════════════════════════════════════════════════════════════════════════════
// Prisma Schema — Bot ML + IA Analyiz (Anderson Honorato)
// Sistema de banco de dados ORM para gerenciamento de produtos, divergências,
// conversas com IA e históricos do Mercado Livre
// ═══════════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELO: USUÁRIO
// ─────────────────────────────────────────────────────────────────────────────
// Armazena dados de autenticação, preferências e configurações do usuário.
// Cada usuário pode ter múltiplas sessões, produtos, divergências e conversas com IA.
model Usuario {
  // Identificadores e autenticação
  id                   Int              @id @default(autoincrement())  // Identificador único sequencial
  email                String           @unique                        // Email único para login
  senha                String                                          // Senha criptografada (hash)
  nome                 String                                          // Nome completo do usuário
  avatar               String?                                         // URL da foto de perfil

  // Status de verificação de conta
  verificado           Boolean          @default(false)                // E-mail foi verificado?
  codigoVerificacao    String?                                         // Código enviado para verificação
  codigoRecuperacao    String?                                         // Código para recuperação de senha

  // Controle de acesso e permissões
  role                 String           @default("BLOQUEADO")          // OWNER | ADMIN_EMPRESA | USUARIO | BLOQUEADO
  solicitouDesbloqueio Boolean          @default(false)                // Solicitação pendente de desbloqueio?

  // Preferências de interface
  tema                 String           @default("dark")               // dark | light
  geminiAtivo          Boolean          @default(true)                 // IA habilitada para esse usuário?

  // Controle de exclusão de conta (soft delete)
  exclusaoPendente     Boolean          @default(false)                // Exclusão solicitada mas não confirmada?
  exclusaoCodigoHash   String?                                         // Hash do código de confirmação
  exclusaoSolicitadaEm DateTime?                                       // Data/hora da solicitação

  // Rastreamento de criação
  createdAt            DateTime         @default(now())                // Data de criação da conta

  // Relacionamentos com outras tabelas
  pesquisasHistorico   PesquisaHistorico[]                            // Histórico de pesquisas de produtos ML
  chatSessions         ChatSession[]                                   // Conversas com a IA
  produtos             Produto[]                                       // Catálogo de produtos do usuário
  divergencias         Divergencia[]                                   // Divergências de peso/frete detectadas
  divergenciaHistorico DivergenciaHistorico[]                         // Histórico de ações em divergências
  mlToken              MlToken?                                        // Token OAuth do Mercado Livre
  agendador            AgendadorConfig?                                // Configuração do agendador automático
  resumosIA            ResumoIA[]                                      // Resumos gerados pela IA
  precificacaoHistorico PrecificacaoHistorico[]                       // Histórico de mudanças de preço
  mlCategorias         MlCategoria[]                                   // Categorias do ML sincronizadas
  avisosML             AvisoML[]                                       // Avisos de saúde da conta ML
  sessoes              SessaoUsuario[]                                 // Sessões de navegação do usuário
  notificacoesIA       ProativaNotificacao[]                          // Notificações automáticas geradas pela IA
  pesquisasMercado     PesquisaMercadoIA[]                            // Pesquisas de análise de concorrência
  feedbacksIA          FeedbackIA[]                                    // Feedback do usuário sobre respostas da IA
}


// ─────────────────────────────────────────────────────────────────────────────
// MODELO: SESSÃO DE CHAT
// ─────────────────────────────────────────────────────────────────────────────
// Agrupa conversas do usuário com a IA em sessões temáticas.
// Cada sessão pode conter múltiplas mensagens e documentos.
model ChatSession {
  id        Int           @id @default(autoincrement())  // Identificador único da sessão
  titulo    String        @default("Nova conversa")       // Título customizável para a conversa
  usuarioId Int                                           // ID do usuário proprietário
  usuario   Usuario       @relation(fields: [usuarioId], references: [id])  // Vínculo com usuário
  messages  ChatMessage[]                                 // Todas as mensagens dentro dessa sessão
  documentos  ChatDocument[]                              // Arquivos e documentos compartilhados
  createdAt DateTime      @default(now())                 // Data de criação da sessão
  updatedAt DateTime      @updatedAt                      // Última atualização
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELO: MENSAGEM DE CHAT
// ─────────────────────────────────────────────────────────────────────────────
// Armazena cada mensagem de uma conversa: perguntas do usuário e respostas da IA.
// Inclui raciocínio interno da IA e análise de imagens quando disponível.
model ChatMessage {
  id          Int         @id @default(autoincrement())  // Identificador único
  sessionId   Int                                         // ID da sessão a qual pertence
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)  // Deletar mensagens quando sessão é deletada
  role        String                                      // "user" = mensagem do usuário | "assistant" = resposta da IA
  content     String      @db.Text                        // Conteúdo da mensagem (texto, até 65KB)
  reasoning   String?     @db.Text                        // Raciocínio interno da IA (Chain of Thought) — não exibido ao usuário
  imageBase64 String?     @db.Text                        // Imagem codificada em base64 (se enviada pelo usuário)
  imageDesc   String?     @db.Text                        // Descrição da imagem gerada pela IA (OCR ou análise visual)
  createdAt   DateTime    @default(now())                 // Timestamp da mensagem
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELO: DOCUMENTOS DO CHAT
// ─────────────────────────────────────────────────────────────────────────────
// Armazena arquivos e códigos gerados ou compartilhados dentro de uma sessão.
// Permite versionamento de código e histórico de documentos.
model ChatDocument {
  id           Int         @id @default(autoincrement())  // Identificador único
  sessionId    Int                                         // ID da sessão a qual pertence
  session      ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)  // Deletar docs quando sessão é deletada
  filename     String                                      // Nome do arquivo (ex: "CardDivergencia.jsx")
  tipo         String                                      // "upload" = arquivo enviado pelo usuário | "gerado" = criado pela IA
  language     String?                                     // Linguagem do código (jsx, python, sql, etc)
  content      String      @db.Text                        // Conteúdo completo do documento/código
  versao       Int         @default(1)                     // Número da versão (para rastrear updates)
  createdAt    DateTime    @default(now())                 // Data de criação/upload
}



// ─────────────────────────────────────────────────────────────────────────────
// MODELO: PRODUTO
// ─────────────────────────────────────────────────────────────────────────────
// Catálogo de produtos do usuário. Sincronizado com Mercado Livre.
// Armazena informações técnicas (peso, dimensões) críticas para detecção de divergências.
model Produto {
  // Identificadores
  id            Int       @id @default(autoincrement())  // Identificador único no banco
  usuarioId     Int                                       // Proprietário do produto
  usuario       Usuario   @relation(fields: [usuarioId], references: [id])  // Vínculo com usuário
  sku           String                                    // SKU do produto (identificador interno da empresa)
  
  // Informações básicas
  nome          String                                    // Nome/descrição do produto
  preco         Float     @default(0)                      // Preço em reais (R$)
  
  // Dimensões e peso (críticos para divergências logísticas)
  pesoGramas    Int       @default(0)                      // Peso total em gramas
  alturaCm      Float     @default(0)                      // Altura em centímetros
  larguraCm     Float     @default(0)                      // Largura em centímetros
  comprimentoCm Float     @default(0)                      // Comprimento em centímetros
  
  // Tipo de produto
  eKit          Boolean   @default(false)                  // É um kit (composto por vários itens)?
  
  // Integração com Mercado Livre
  mlItemId      String?                                    // ID do anúncio no ML (quando sincronizado)
  categoria     String?                                    // Categoria no ML
  plataforma    String    @default("Mercado Livre")        // Plataforma principal (ML, Shopee, Amazon, etc)
  
  // Status e exibição
  status        String    @default("active")              // active | inativo | pausado | excluido
  thumbnail     String?                                   // URL da imagem do produto
  descricao     String?   @db.Text                         // Descrição completa do produto
  
  // Ficha técnica completa (informações técnicas detalhadas)
  ean           String?                                   // Código EAN/GTIN para rastreabilidade
  marca         String?                                   // Marca ou fabricante do produto
  modelo        String?                                   // Modelo ou referência específica
  condicao      String?   @default("Novo")                // Novo | Usado | Recondicionado
  
  // Relacionamentos
  itensDoKit    KitItem[] @relation("KitPai")             // Se é kit: quais produtos compõem este kit
  parteDeKits   KitItem[] @relation("ItemFilho")          // Se é item: quais kits o contêm
  
  // Garantir SKU único por usuário (não pode ter dois SKUs iguais para mesmo usuário)
  @@unique([usuarioId, sku])
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELO: ITEM DE KIT
// ─────────────────────────────────────────────────────────────────────────────
// Relacionamento muitos-para-muitos: produtos que fazem parte de um kit.
model KitItem {
  id         Int     @id @default(autoincrement())  // Identificador único
  kitId      Int                                     // ID do kit (produto pai)
  produtoId  Int                                     // ID do produto que faz parte do kit
  quantidade Int                                     // Quantidade deste produto no kit
  kit        Produto @relation("KitPai", fields: [kitId], references: [id])  // O kit proprietário
  produto    Produto @relation("ItemFilho", fields: [produtoId], references: [id])  // O produto pertencente
}



// ─────────────────────────────────────────────────────────────────────────────
// MODELO: DIVERGÊNCIA
// ─────────────────────────────────────────────────────────────────────────────
// Registra divergências de peso/frete entre o declarado no ML e o cobrado.
// Essencial para detecção de erros logísticos e impacto financeiro.
model Divergencia {
  id         Int      @id @default(autoincrement())  // Identificador único
  usuarioId  Int                                      // ID do usuário proprietário
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])  // Vínculo com usuário
  mlItemId   String                                   // ID do anúncio no Mercado Livre onde divergência foi detectada
  link       String                                   // URL completa para acessar o anúncio no ML
  motivo     String                                   // Descrição do motivo da divergência
  
  // Dados técnicos da divergência
  pesoMl     Int      @default(0)                     // Peso declarado no ML (gramas)
  pesoLocal  Int      @default(0)                     // Peso cadastrado localmente no sistema (gramas)

  // Status da divergência (pipeline de resolução)
  // PENDENTE: detectada, aguardando ação do usuário ou automática
  // PENDENTE_ENVIO: usuário vai corrigir, enviando dados para ML
  // REINCIDENTE: foi corrigida mas voltou a divergir (alerta de prioridade alta)
  // CORRIGIDO: resolvida definitivamente
  // IGNORADO: usuário optou por ignorar (não vai corrigir)
  status     String   @default("PENDENTE")            // Estado atual da divergência

  resolvido  Boolean  @default(false)                 // Marca final de resolução?

  // Rastreamento de como foi corrigida
  corrigidoViaApi  Boolean  @default(false)           // true = sistema corrigiu automaticamente via API ML
  corrigidoManual  Boolean  @default(false)           // true = usuário confirmou que corrigiu manualmente no ML

  // Metadados
  plataforma String   @default("Mercado Livre")       // Plataforma onde divergência foi detectada
  titulo     String?                                  // Título do anúncio (snapshot no momento da detecção)
  createdAt  DateTime @default(now())                 // Data/hora da detecção

  // Relacionamentos
  historico  DivergenciaHistorico[]                   // Histórico de todas as ações tomadas
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELO: HISTÓRICO DE DIVERGÊNCIA
// ─────────────────────────────────────────────────────────────────────────────
// Auditoria completa: registra cada ação tomada em uma divergência.
// Essencial para análise de tendências e reincidências.
model DivergenciaHistorico {
  id            Int         @id @default(autoincrement())  // Identificador único
  divergenciaId Int                                         // ID da divergência relacionada
  divergencia   Divergencia @relation(fields: [divergenciaId], references: [id], onDelete: Cascade)  // Deletar histórico com divergência
  usuarioId     Int                                         // ID do usuário que fez a ação
  usuario       Usuario     @relation(fields: [usuarioId], references: [id])  // Vínculo com usuário

  // Registro da ação
  acao          String                                      // Tipo: CORRIGIDO_MANUAL | CORRIGIDO_API | IGNORADO | REABERTO | PENDENTE_ENVIO
  descricao     String      @db.Text                        // Descrição descritiva da ação
  detalhes      String?     @db.Text                        // Dados técnicos em JSON (before/after, parâmetros, etc)

  createdAt     DateTime    @default(now())                 // Data/hora da ação
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELO: AVISOS DO MERCADO LIVRE
// ─────────────────────────────────────────────────────────────────────────────
// Alertas de saúde de conta do ML: dimensões incorretas, penalidades, etc.
// O ML automaticamente desativa anúncios com problemas críticos.
model AvisoML {
  id          Int      @id @default(autoincrement())  // Identificador único
  usuarioId   Int                                      // ID do usuário proprietário
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])  // Vínculo com usuário
  mlItemId    String                                   // ID do anúncio afetado
  titulo      String?                                  // Título do anúncio (quando disponível)
  thumbnail   String?                                  // Preview de imagem (quando disponível)

  // Classificação do aviso
  // DIMENSOES_INCORRETAS: ML detectou que dimensões não batem com peso
  // PESO_INCORRETO: peso declarado e cobrado são diferentes
  // ANUNCIO_PAUSADO: ML pausou automaticamente por problemas críticos
  // OUTROS: avisos genéricos ou não classificados
  tipoAviso   String   @default("DIMENSOES_INCORRETAS")  // Tipo do aviso

  mensagem    String   @db.Text                        // Texto completo do aviso do ML
  
  // Severidade: priorização para o usuário
  // ALTO: afeta anúncios, penalidades, reputação
  // MEDIO: avisos para resolver em breve
  // BAIXO: informativos, não há risco imediato
  severidade  String   @default("ALTO")                 // Nível de criticidade

  // Status de resolução
  resolvido   Boolean  @default(false)                  // Aviso foi resolvido?
  resolvidoEm DateTime?                                 // Data/hora da resolução

  ativo       Boolean  @default(true)                   // Aviso ainda está vigendo?
  createdAt   DateTime @default(now())                  // Data de criação
  updatedAt   DateTime @updatedAt                       // Última atualização

  // Evitar duplicação de avisos para mesmo item e tipo
  @@unique([usuarioId, mlItemId, tipoAviso])
}



// ─────────────────────────────────────────────────────────────────────────────
// MODELO: TOKEN MERCADO LIVRE
// ─────────────────────────────────────────────────────────────────────────────
// Armazena credenciais OAuth do Mercado Livre de forma segura.
// Cada usuário tem um token único que autoriza acesso à sua conta ML.
model MlToken {
  id           Int      @id @default(autoincrement())  // Identificador único
  usuarioId    Int      @unique                         // Um token por usuário
  usuario      Usuario  @relation(fields: [usuarioId], references: [id])  // Vínculo com usuário
  accessToken  String   @db.Text                        // Token de acesso OAuth (privado, nunca expor)
  refreshToken String   @db.Text                        // Token para renovar accessToken sem reautenticação
  expiresAt    DateTime                                 // Quando o accessToken expira (requer renovação)
  mlUserId     String   @default("")                    // ID único do usuário dentro do Mercado Livre
  nickname     String   @default("")                    // Nickname/username do usuário no ML
  createdAt    DateTime @default(now())                 // Quando token foi gerado
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELO: CONFIGURAÇÃO DO AGENDADOR
// ─────────────────────────────────────────────────────────────────────────────
// Controla execução automática de varreduras de divergências e sincronização.
// Cada usuário pode ativar/desativar e configurar intervalo.
model AgendadorConfig {
  id              Int       @id @default(autoincrement())  // Identificador único
  usuarioId       Int       @unique                         // Um agendador por usuário
  usuario         Usuario   @relation(fields: [usuarioId], references: [id])  // Vínculo com usuário
  ativo           Boolean   @default(false)                 // Agendador está ativado?
  intervalo       Int       @default(360)                   // Minutos entre execuções (padrão: 6 horas)
  ultimaExecucao  DateTime?                                 // Timestamp da última varredura realizada
  proximaExecucao DateTime?                                 // Timestamp previsto da próxima varredura
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELO: RESUMO GERADO PELA IA
// ─────────────────────────────────────────────────────────────────────────────
// Armazena resumos e relatórios gerados pela IA para o usuário.
model ResumoIA {
  id        Int      @id @default(autoincrement())  // Identificador único
  usuarioId Int                                      // Proprietário do resumo
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])  // Vínculo com usuário
  conteudo  String   @db.Text                        // Conteúdo completo do resumo (HTML ou markdown)
  createdAt DateTime @default(now())                 // Data de criação do resumo
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELO: HISTÓRICO DE PRECIFICAÇÃO
// ─────────────────────────────────────────────────────────────────────────────
// Rastreia todas as mudanças de preço de produtos.
// Essencial para análise de tendências e repricing automático.
model PrecificacaoHistorico {
  id              Int      @id @default(autoincrement())  // Identificador único
  usuarioId       Int                                      // Proprietário
  usuario         Usuario  @relation(fields: [usuarioId], references: [id])  // Vínculo com usuário
  mlItemId        String                                   // ID do anúncio no ML que teve preço alterado
  preco           Float                                    // Novo preço em reais
  quantidade      Int      @default(1)                     // Quantidade disponível neste preço
  titulo          String   @default("")                    // Título do produto (snapshot)
  categoriaId     String   @default("")                    // Categoria do ML (snapshot)
  atualizadoPor   String?                                  // Quem fez a atualização (user_id ou 'sistema')
  criadoEm        DateTime @default(now())                 // Data/hora da mudança
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELO: CATEGORIAS DO MERCADO LIVRE
// ─────────────────────────────────────────────────────────────────────────────
// Cache local das categorias disponíveis no ML para este usuário.
model MlCategoria {
  id          Int     @id @default(autoincrement())  // Identificador único
  usuarioId   Int                                     // Proprietário
  usuario     Usuario @relation(fields: [usuarioId], references: [id])  // Vínculo com usuário
  categoriaId String                                  // ID único da categoria no ML
  nome        String                                  // Nome amigável da categoria

  // Garantir que não há categoria duplicada para mesmo usuário
  @@unique([usuarioId, categoriaId])
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELO: SESSÃO DE USUÁRIO
// ─────────────────────────────────────────────────────────────────────────────
// Rastreia sessões de navegação: quando usuário entrou e saiu do sistema.
model SessaoUsuario {
  id        Int      @id @default(autoincrement())  // Identificador único
  usuarioId Int                                      // ID do usuário
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])  // Vínculo com usuário
  entradaEm DateTime @default(now())                 // Quando o usuário fez login
  saidaEm   DateTime?                                // Quando o usuário fez logout (null = ainda ativo)
  ativo     Boolean  @default(true)                  // Sessão está ativa?
  userAgent String?                                  // Navegador/cliente usado (para análise)
  ip        String?                                  // IP do usuário (para segurança e análise)
 
  // Índices para queries rápidas
  @@index([usuarioId])
  @@index([ativo])
}



// ─────────────────────────────────────────────────────────────────────────────
// MODELO: CONHECIMENTO DA IA
// ─────────────────────────────────────────────────────────────────────────────
// Base de conhecimento aprendido pela IA durante sua operação.
// Cada "fato" tem nível de confiança e é reutilizável em futuras conversas.
model IaConhecimento {
  id           Int      @id @default(autoincrement())  // Identificador único
  categoria    String                                   // Categoria: metricas_sistema | logistica | conversa | etc
  chave        String                                   // Chave única do conhecimento (ex: "taxa_divergencia_media")
  valor        String   @db.Text                        // O conhecimento propriamente dito (conteúdo)
  confianca    Float    @default(0.5)                   // Nível de confiança de 0.0 (baixa) a 1.0 (alta)
  fonte        String   @default("sistema")             // Origem: sistema | validacao_ia | conversa_usuario | analise_autonoma
  usos         Int      @default(0)                     // Quantas vezes este conhecimento foi utilizado/consultado
  atualizadoEm DateTime @default(now())                 // Última atualização do conhecimento
  createdAt    DateTime @default(now())                 // Quando foi registrado
  embedding    Float[]                                  // Embedding vetorial para buscas por similaridade (RAG)

  // Evitar duplicação de conhecimento na mesma categoria
  @@unique([categoria, chave])
  @@index([categoria])
  @@index([confianca])
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELO: APRENDIZADO DA IA
// ─────────────────────────────────────────────────────────────────────────────
// Registra cada interação da IA: pergunta, tentativa de resposta, resposta final, aprovação.
// Essencial para auditoria, refinamento e análise de performance.
model IaAprendizado {
  id                 Int      @id @default(autoincrement())  // Identificador único
  pergunta           String   @db.Text                        // Pergunta do usuário
  respostaTentativa  String   @db.Text                        // Primeira resposta gerada (antes de validação)
  respostaFinal      String   @db.Text                        // Resposta final enviada ao usuário
  aprovada           Boolean                                  // A resposta foi validada e aprovada?
  confianca          Float    @default(0.5)                   // Nível de confiança da resposta (0-1)
  motivo             String?                                  // Explicação de por que foi aprovada/reprovada
  usuarioId          Int?                                     // Qual usuário gerou esta interação (para feedback)
  createdAt          DateTime @default(now())                 // Quando ocorreu
  embedding          Float[]                                  // Embedding para análise de similaridade

  // Índices para queries rápidas
  @@index([aprovada])
  @@index([usuarioId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELO: LOG DE ESTUDO DA IA
// ─────────────────────────────────────────────────────────────────────────────
// Terminal visível de tudo que a IA estuda/pensa/aprende.
// Essencial para debug e compreensão do comportamento autônomo da IA.
model IaEstudoTerminal {
  id        Int      @id @default(autoincrement())  // Identificador único
  tipo      String                                   // Tipo: analise_sistema | mentoria_gemini | aprendizado_conversa | etc
  resumo    String   @db.Text                        // Resumo do que foi estudado (1-2 parágrafos)
  detalhes  String?  @db.Text                        // Detalhes técnicos em JSON (dados completos da análise)
  createdAt DateTime @default(now())                 // Data/hora da análise

  // Índices para buscas rápidas
  @@index([tipo])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELO: HISTÓRICO DE PESQUISAS
// ─────────────────────────────────────────────────────────────────────────────
// Registro de todas as pesquisas/consultas de produtos ML realizadas pelo usuário.
// Permite histórico, arquivamento e análise de padrões de busca.
model PesquisaHistorico {
  id          Int       @id @default(autoincrement())  // Identificador único
  usuarioId   Int                                       // Proprietário da pesquisa
  usuario     Usuario   @relation(fields: [usuarioId], references: [id])  // Vínculo com usuário

  mlbId       String                                    // ID do anúncio pesquisado no ML
  urlOriginal String    @db.Text                        // URL exata que o usuário colou/pesquisou
  titulo      String?                                   // Título do anúncio (quando encontrado)
  thumbnail   String?                                   // URL da imagem do produto
  preco       Float?                                    // Preço no momento da pesquisa

  dadosJson   String?   @db.Text                        // JSON bruto dos dados do anúncio (backup completo)
  erro        String?   @db.Text                        // Mensagem de erro (se pesquisa falhou)
  status      String    @default("concluido")           // concluido | erro

  arquivado   Boolean   @default(false)                 // Movido para arquivo/histórico?
  excluido    Boolean   @default(false)                 // Soft delete (não realmente excluído)
  excluidoEm  DateTime?                                 // Data da exclusão

  createdAt   DateTime  @default(now())                 // Data da pesquisa
  updatedAt   DateTime  @updatedAt                      // Última atualização

  // Evitar duplicação de mesma pesquisa
  @@unique([usuarioId, mlbId])
  @@index([usuarioId])
  @@index([arquivado])
  @@index([excluido])
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELO: NOTIFICAÇÃO PROATIVA DA IA
// ─────────────────────────────────────────────────────────────────────────────
// Notificações geradas automaticamente pela IA para alertar sobre situações importantes.
// Controla exibição em balão flutuante e evita "encher o saco" com notificações repetidas.
model ProativaNotificacao {
  id            Int       @id @default(autoincrement())  // Identificador único
  usuarioId     Int                                       // Destinatário
  usuario       Usuario   @relation(fields: [usuarioId], references: [id])  // Vínculo com usuário

  // Conteúdo da notificação em dois níveis
  resumoBotao   String                                    // Texto curto para balão (máx 70 chars)
  fullInsight   String    @db.Text                        // Conteúdo completo para exibir no chat

  // Deduplicação: evita notificações repetidas do mesmo contexto
  contextoHash  String                                    // Hash MD5 do contexto (impede duplicatas)

  // Rastreamento de visualização
  exibidaBotao  Boolean   @default(false)                 // Balão foi mostrado?
  vistaNoChat   Boolean   @default(false)                 // Usuário abriu e viu no chat?
  vistaEm       DateTime?                                 // Timestamp de quando viu

  createdAt     DateTime  @default(now())                 // Criação da notificação

  // Índices para queries de notificações não vistas
  @@index([usuarioId, vistaNoChat])
  @@index([usuarioId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELO: PESQUISA DE ANÁLISE DE MERCADO
// ─────────────────────────────────────────────────────────────────────────────
// Relatórios de análise de concorrência e mercado gerados pela IA.
model PesquisaMercadoIA {
  id            Int      @id @default(autoincrement())  // Identificador único
  usuarioId     Int                                      // Proprietário
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])  // Vínculo com usuário
  
  mlbIds        String   @db.Text                        // IDs dos anúncios analisados (JSON ou vírgula-separado)
  
  titulo        String                                   // Título do relatório (ex: "Análise: Galaxy S24 + concorrentes")
  conteudoHtml  String   @db.Text                        // Relatório HTML gerado pela IA (análise completa)
  
  // Métricas extraídas para facilitara análise futura
  precoMedio    Float?                                   // Preço média entre os concorrentes
  melhorPreco   Float?                                   // Menor preço encontrado
  oportunidade  String?  @db.Text                        // Resumo da oportunidade identificada
  
  createdAt     DateTime @default(now())                 // Data da análise

  @@index([usuarioId])
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELO: FEEDBACK DO USUÁRIO SOBRE RESPOSTAS DA IA
// ─────────────────────────────────────────────────────────────────────────────
// Sistema de feedback simples: Gostei (👍) ou Não Gostei (👎) + comentário opcional.
// Essencial para treinamento contínuo da IA.
model FeedbackIA {
  id          Int      @id @default(autoincrement())  // Identificador único
  usuarioId   Int                                      // Quem deixou o feedback
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])  // Vínculo com usuário
  mensagemId  String                                   // ID único da mensagem no frontend (ex: 'ia-12345')
  isPositive  Boolean                                  // true = Gostei | false = Não gostei
  comentario  String?  @db.Text                        // Comentário adicional do usuário (opcional)
  createdAt   DateTime @default(now())                 // Data do feedback

  @@index([usuarioId])
}